{
  "name": "quorum",
  "version": "0.1.0",
  "private": true,
  "description": "On-chain governance infrastructure for the Stellar and Soroban ecosystem",
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "build:sdk": "cd sdk && npm run build",
    "build:contracts": "cd contracts && cargo build --target wasm32-unknown-unknown --release",
    "lint": "cd frontend && npm run lint",
    "test": "cd frontend && npm test -- --passWithNoTests"
  },
  "engines": {
    "node": ">=18"
  }
}